{
    "name": "palmwtc",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-toolsai.jupyter",
                "charliermarsh.ruff"
            ],
            "settings": {
                "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python"
            }
        }
    },
    "remoteUser": "vscode",
    "mounts": [
        "source=palmwtc-uv-cache,target=/home/vscode/.cache/uv,type=volume"
    ],
    "postCreateCommand": "uv sync"
}
